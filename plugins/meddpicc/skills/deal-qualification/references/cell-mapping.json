{
  "$comment": "Maps JSON paths from meddpicc-schema.json to cell coordinates in meddpicc-template.xlsx. The XLS template uses the 'MEDDPICC Deal Review Sheet' sheet. Dynamic rows (stakeholders, milestones, team) start at the given row and increment by 1 per item. Sections sharing the same startRow use side-by-side layout (different column ranges on the same rows).",
  "sheetName": "MEDDPICC Deal Review Sheet",
  "staticFields": [
    { "jsonPath": "metadata.accountName", "cell": "B4" },
    { "jsonPath": "metadata.competition", "cell": "G4" },
    { "jsonPath": "metadata.revenue.pAndIplusAcvx", "cell": "M4", "format": "currency" },
    { "jsonPath": "metadata.dealName", "cell": "B5" },
    { "jsonPath": "metadata.winProbability", "cell": "G5", "format": "percentage" },
    { "jsonPath": "metadata.revenue.hardware", "cell": "M5", "format": "currency" },
    { "jsonPath": "metadata.dealStatus", "cell": "B6", "format": "picklist" },
    { "jsonPath": "metadata.forecastStage", "cell": "G6", "format": "picklist" },
    { "jsonPath": "metadata.revenue.software", "cell": "N6", "format": "currency" },
    { "jsonPath": "metadata.closeDate", "cell": "B7", "format": "date" },
    { "jsonPath": "metadata.revenue.acv", "cell": "N7", "format": "currency" },
    { "jsonPath": "metadata.lastClientInteraction.date", "cell": "D9", "format": "date" },
    { "jsonPath": "metadata.lastClientInteraction.outcome", "cell": "F9" },
    { "jsonPath": "metadata.nextClientInteraction.date", "cell": "D10", "format": "date" },
    { "jsonPath": "metadata.nextClientInteraction.objective", "cell": "F10" },
    { "jsonPath": "qualification.metrics.responses[0]", "cell": "C14" },
    { "jsonPath": "qualification.metrics.responses[1]", "cell": "C15" },
    { "jsonPath": "qualification.economicBuyer.responses[0]", "cell": "C16" },
    { "jsonPath": "qualification.economicBuyer.responses[1]", "cell": "C17" },
    { "jsonPath": "qualification.decisionCriteria.responses[0]", "cell": "C18" },
    { "jsonPath": "qualification.decisionCriteria.responses[1]", "cell": "C19" },
    { "jsonPath": "qualification.decisionProcess.responses[0]", "cell": "C20" },
    { "jsonPath": "qualification.decisionProcess.responses[1]", "cell": "C21" },
    { "jsonPath": "qualification.paperProcess.responses[0]", "cell": "C22" },
    { "jsonPath": "qualification.paperProcess.responses[1]", "cell": "C23" },
    { "jsonPath": "qualification.implicateThePain.responses[0]", "cell": "C24" },
    { "jsonPath": "qualification.implicateThePain.responses[1]", "cell": "C25" },
    { "jsonPath": "qualification.champion.responses[0]", "cell": "C26" },
    { "jsonPath": "qualification.champion.responses[1]", "cell": "C27" },
    { "jsonPath": "qualification.competition.responses[0]", "cell": "C28" },
    { "jsonPath": "qualification.competition.responses[1]", "cell": "C29" },
    { "jsonPath": "threeWhys.f5.whyAnything", "cell": "B34" },
    { "jsonPath": "threeWhys.f5.whyF5", "cell": "B35" },
    { "jsonPath": "threeWhys.f5.whyNow", "cell": "B36" },
    { "jsonPath": "threeWhys.partner.whyAnything", "cell": "J34" },
    { "jsonPath": "threeWhys.partner.whyThisPartner", "cell": "J35" },
    { "jsonPath": "threeWhys.partner.whyNow", "cell": "J36" },
    { "jsonPath": "salesStrategy.differentiatedValueProposition", "cell": "B55" },
    { "jsonPath": "salesStrategy.winStrategy", "cell": "J55" }
  ],
  "dynamicSections": [
    {
      "jsonPath": "stakeholders",
      "startRow": 41,
      "maxRows": 12,
      "columns": {
        "name": "B",
        "title": "D",
        "roleInDeal": "F",
        "mustSayYes": "H",
        "canSayNo": "I",
        "whatTheyNeedToBelieve": "J",
        "viewOfF5": "P",
        "f5Owner": "Q"
      },
      "booleanFormat": { "true": "Yes", "false": "No" }
    },
    {
      "jsonPath": "closePlan.milestones",
      "startRow": 67,
      "maxRows": 10,
      "layout": "side-by-side",
      "columns": {
        "description": "B",
        "targetDate": "F",
        "status": "H"
      }
    },
    {
      "jsonPath": "closePlan.criticalActions",
      "startRow": 67,
      "maxRows": 10,
      "layout": "side-by-side",
      "columns": {
        "action": "J",
        "owner": "N",
        "dueDate": "P",
        "status": "Q"
      }
    },
    {
      "jsonPath": "team.f5",
      "startRow": 82,
      "maxRows": 10,
      "layout": "side-by-side",
      "columns": {
        "name": "B",
        "role": "D",
        "dateRequiredFrom": "F",
        "assignedToDeal": "H"
      },
      "booleanFormat": { "true": "Yes", "false": "No" }
    },
    {
      "jsonPath": "team.partner",
      "startRow": 82,
      "maxRows": 10,
      "layout": "side-by-side",
      "columns": {
        "name": "J",
        "role": "L",
        "dateRequiredFrom": "N",
        "assignedToDeal": "P"
      },
      "booleanFormat": { "true": "Yes", "false": "No" }
    }
  ]
}
