      "tags": ["json", "lsp", "language-server"],
      "repository": "https://github.com/f5xc-salesdemos/marketplace",
      "lspServers": {
        "json": {
          "command": "vscode-json-language-server",
          "args": ["--stdio"],
          "extensionToLanguage": {
            ".json": "json",
            ".jsonc": "jsonc"
          }
